rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tournaments/{id} {

      // Qualquer um pode ler
      allow read: if true;

      // Qualquer um pode atualizar apenas o campo "players"
      allow update: if !request.auth != null
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['players']);

      // Só admin autenticado pode criar, alterar tudo e excluir torneios
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Pontos manuais históricos: leitura pública, escrita só admin autenticado
    match /rankingConfig/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mensalidades: leitura pública, escrita livre (atletas confirmam sem login)
    match /mensalidades/{id} {
      allow read: if true;
      allow write: if true;
    }
  }
}
